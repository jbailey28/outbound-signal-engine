# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Supabase (used by the loader in a later step, not by the M1 import script)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Discord webhook for import notifications (optional, later milestone)
DISCORD_WEBHOOK_URL=

# Claude API — only needed for `generate_drafts.py --llm` (LLM-written drafts)
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-8). e.g. claude-haiku-4-5 for lower cost.
ANTHROPIC_MODEL=
